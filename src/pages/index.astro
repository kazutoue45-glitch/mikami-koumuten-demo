---
import Base from '../layouts/Base.astro';
import Cta from '../components/Cta.astro';
const base = import.meta.env.BASE_URL;
---
<Base title="ホーム">

  <section class="hero">
    <img src={`${base}images/hyoushou-shiki.jpg`} alt="" class="hero__bg" />
    <div class="hero__gradient"></div>
    <div class="hero__73" aria-hidden="true">73</div>
    <div class="hero__content">
      <p class="hero__catch">創業昭和28年。<br />札幌の街を守り続けて。</p>
      <div class="hero__award-row">
        <span class="hero__award-badge">札幌市優良工事表彰 通算<strong>13</strong>回受賞</span>
      </div>
      <a href={`${base}contact/`} class="btn btn--primary hero__cta">無料で相談してみる</a>
    </div>
  </section>

  <section class="service">
    <div class="container">
      <div class="section-header">
        <span class="section-header__en">Service</span>
        <h2 class="section-header__ja">事業内容</h2>
      </div>
      <div class="service__grid">
        <a href={`${base}works/`} class="service__item">
          <div class="service__img-wrap">
            <img src={`${base}images/public-works.jpg`} alt="公共建築工事" width="800" height="600" />
          </div>
          <div class="service__body">
            <h3 class="service__title">公共建築工事</h3>
            <p class="service__text">区役所の耐震工事、小学校の外部改修、地下鉄のホーム改修、市立病院の外壁改修。札幌市の公共インフラを支えています。</p>
          </div>
        </a>
        <a href={`${base}works/`} class="service__item">
          <div class="service__img-wrap">
            <img src={`${base}images/postal.jpg`} alt="施設修繕" width="800" height="600" />
          </div>
          <div class="service__body">
            <h3 class="service__title">施設修繕</h3>
            <p class="service__text">札幌市東部エリアの郵便局122局の修繕指定業者。NTTドコモ基地局の新設工事も15局以上手がけています。</p>
          </div>
        </a>
        <a href={`${base}works/`} class="service__item">
          <div class="service__img-wrap">
            <img src={`${base}images/renovation.jpg`} alt="個人住宅リフォーム" width="800" height="600" />
          </div>
          <div class="service__body">
            <h3 class="service__title">個人住宅リフォーム</h3>
            <p class="service__text">公共工事で培った品質基準で、ご自宅のリフォームにも対応。大きな工事から小さな修繕まで、お気軽にご相談ください。</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="works-hl">
    <div class="container">
      <div class="section-header">
        <span class="section-header__en">Works</span>
        <h2 class="section-header__ja">施工実績</h2>
      </div>
      <div class="works-hl__item">
        <div class="works-hl__img-wrap">
          <img src={`${base}images/community-center.jpg`} alt="曙まちづくりセンター新築工事" width="800" height="600" />
        </div>
        <div class="works-hl__body">
          <span class="works-hl__tag">公共建築</span>
          <h3 class="works-hl__title">曙まちづくりセンター新築工事</h3>
          <p class="works-hl__meta">2024年10月竣工（JV）</p>
          <p class="works-hl__desc">札幌市都市局から令和5年度優良工事施工業者として表彰を受けた代表的な施工実績です。</p>
        </div>
      </div>
      <div class="works-hl__more">
        <a href={`${base}works/`} class="btn btn--primary">施工実績をもっと見る</a>
      </div>
    </div>
  </section>

  <section class="proof">
    <div class="container">
      <div class="section-header">
        <span class="section-header__en">Trust</span>
        <h2 class="section-header__ja">信頼の証</h2>
      </div>
      <div class="proof__numbers">
        <div class="proof__num-item">
          <span class="proof__num-value">1953</span>
          <span class="proof__num-label">年創業</span>
        </div>
        <div class="proof__num-item">
          <span class="proof__num-value">13</span>
          <span class="proof__num-label">回 札幌市優良工事表彰</span>
        </div>
        <div class="proof__num-item">
          <span class="proof__num-value">122</span>
          <span class="proof__num-label">局 郵便局修繕指定</span>
        </div>
      </div>
      <div class="proof__badges">
        <img src={`${base}images/kenkou-keiei.jpg`} alt="健康経営優良法人2026" width="200" />
        <img src={`${base}images/sapporo-sdgs.jpg`} alt="SAPPORO SDGs" width="150" />
        <img src={`${base}images/sapporo-qms.gif`} alt="サッポロQMS" width="80" />
      </div>
    </div>
  </section>

  <Cta />

</Base>

<style>
  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    max-height: 900px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    z-index: 0;
  }
  .hero__gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(to top, rgba(0,80,75,0.8) 0%, rgba(0,80,75,0.4) 35%, transparent 65%),
      linear-gradient(to right, rgba(0,80,75,0.3) 0%, transparent 50%);
  }
  .hero__73 {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -55%);
    font-family: var(--ff-condensed);
    font-size: clamp(14rem, 35vw, 28rem);
    font-weight: 700;
    color: rgba(255,255,255,0.45);
    line-height: 0.8;
    pointer-events: none;
    z-index: 2;
    letter-spacing: -0.04em;
    mix-blend-mode: overlay;
    text-shadow: 0 0 80px rgba(255,255,255,0.3);
  }
  .hero__content {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--sp-md) var(--sp-3xl);
  }
  .hero__catch {
    font-family: var(--ff-serif);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 700;
    color: var(--c-white);
    line-height: 1.6;
    margin-bottom: var(--sp-md);
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }
  .hero__award-row {
    margin-bottom: var(--sp-lg);
  }
  .hero__award-badge {
    display: inline-block;
    background: var(--c-primary);
    color: var(--c-white);
    padding: 8px 24px;
    border-radius: 4px;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }
  .hero__award-badge strong {
    font-family: var(--ff-condensed);
    font-size: 1.5rem;
    margin: 0 3px;
  }

  @media (max-width: 768px) {
    .hero { height: 85vh; min-height: 500px; }
    .hero__bg { object-position: 60% 15%; }
    .hero__73 { font-size: 10rem; }
    .hero__gradient {
      background:
        linear-gradient(to top, rgba(0,80,75,0.85) 0%, rgba(0,80,75,0.5) 40%, transparent 70%);
    }
    .hero__content { padding-bottom: var(--sp-xl); }
  }

  .service { padding: var(--sp-4xl) 0; background: var(--c-white); }
  .service__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-lg); }
  .service__item { display: block; overflow: hidden; border-radius: 6px; background: var(--c-warm-gray); transition: var(--transition); }
  .service__item:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
  .service__img-wrap { overflow: hidden; }
  .service__img-wrap img { width: 100%; aspect-ratio: 4/3; object-fit: cover; transition: transform 0.4s ease; }
  .service__item:hover .service__img-wrap img { transform: scale(1.04); }
  .service__body { padding: var(--sp-md); }
  .service__title { font-family: var(--ff-serif); font-size: var(--fs-h3); font-weight: 700; color: var(--c-primary-dark); margin-bottom: var(--sp-xs); }
  .service__text { font-size: var(--fs-small); color: var(--c-text-light); line-height: 1.8; }
  @media (max-width: 768px) { .service__grid { grid-template-columns: 1fr; } }

  .works-hl { padding: var(--sp-4xl) 0; background: var(--c-warm-gray); }
  .works-hl__item { display: grid; grid-template-columns: 1.2fr 1fr; gap: var(--sp-xl); align-items: center; }
  .works-hl__img-wrap { border-radius: 6px; overflow: hidden; }
  .works-hl__img-wrap img { width: 100%; aspect-ratio: 4/3; object-fit: cover; }
  .works-hl__tag { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--c-primary); background: var(--c-primary-light); padding: 4px 12px; border-radius: 3px; margin-bottom: var(--sp-sm); }
  .works-hl__title { font-family: var(--ff-serif); font-size: var(--fs-h3); font-weight: 700; color: var(--c-primary-dark); margin-bottom: var(--sp-xs); }
  .works-hl__meta { font-size: var(--fs-small); color: var(--c-text-light); margin-bottom: var(--sp-sm); }
  .works-hl__desc { font-size: var(--fs-small); color: var(--c-text); line-height: 1.8; }
  .works-hl__more { text-align: center; margin-top: var(--sp-xl); }
  @media (max-width: 768px) { .works-hl__item { grid-template-columns: 1fr; } }

  .proof { padding: var(--sp-4xl) 0; background: var(--c-white); }
  .proof__numbers { display: flex; justify-content: center; gap: var(--sp-2xl); margin-bottom: var(--sp-xl); flex-wrap: wrap; }
  .proof__num-item { text-align: center; }
  .proof__num-value { font-family: var(--ff-condensed); font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 700; color: var(--c-primary-dark); line-height: 1.1; display: block; }
  .proof__num-label { font-size: var(--fs-small); color: var(--c-text-light); display: block; margin-top: 4px; }
  .proof__badges { display: flex; justify-content: center; align-items: center; gap: var(--sp-lg); flex-wrap: wrap; padding: var(--sp-lg); background: var(--c-warm-gray); border-radius: 8px; }
</style>
