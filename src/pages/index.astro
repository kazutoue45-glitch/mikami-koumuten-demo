---
import Base from '../layouts/Base.astro';
import Cta from '../components/Cta.astro';
const base = import.meta.env.BASE_URL;
---
<Base title="ホーム">

  <section class="hero">
    <img src={`${base}images/nature-hero.jpg`} alt="" class="hero__bg" />
    <div class="hero__content">
      <h1 class="hero__heading">
        <span class="hero__line">創業昭和28年。</span>
        <span class="hero__line">札幌の街を守り続けて、</span>
        <span class="hero__line hero__line--num">73<span class="hero__line--unit">年。</span></span>
      </h1>
      <p class="hero__sub">札幌市優良工事表彰 通算13回受賞</p>
      <a href={`${base}contact/`} class="hero__cta-btn">まずはご相談ください</a>
    </div>
    <div class="hero__kenkou">
      <img src={`${base}images/kenkou-keiei.jpg`} alt="健康経営優良法人2026" width="160" />
      <span class="hero__kenkou-text">健康経営優良法人2026 認定</span>
    </div>
  </section>

  <section class="service">
    <div class="container">
      <div class="section-header">
        <span class="section-header__en">Service</span>
        <h2 class="section-header__ja">事業内容</h2>
      </div>
      <p class="service__lead">公共建築工事を主軸に営業しております。区役所の耐震工事、小学校の外部改修、地下鉄のホーム改修、水道局の施設の工事、市立病院の外壁改修など、様々な公共工事を手がけています。</p>
      <div class="service__grid">
        <a href={`${base}works/`} class="service__item">
          <div class="service__img-wrap">
            <img src={`${base}images/public-works.jpg`} alt="公共建築工事" width="800" height="600" />
          </div>
          <div class="service__body">
            <h3 class="service__title">公共建築工事</h3>
            <p class="service__text">区役所・小学校・地下鉄・水道局・市立病院など、札幌市の公共インフラを支える工事を主軸に営業しています。</p>
          </div>
        </a>
        <a href={`${base}works/`} class="service__item">
          <div class="service__img-wrap">
            <img src={`${base}images/postal.jpg`} alt="郵便局修繕" width="800" height="600" />
          </div>
          <div class="service__body">
            <h3 class="service__title">郵便局・通信施設</h3>
            <p class="service__text">札幌市東部エリアの郵便局122局の修繕指定業者。NTTドコモ基地局の新設工事も15局以上手がけました。</p>
          </div>
        </a>
        <a href={`${base}works/`} class="service__item">
          <div class="service__img-wrap">
            <img src={`${base}images/community-center.jpg`} alt="曙まちづくりセンター" width="800" height="600" />
          </div>
          <div class="service__body">
            <h3 class="service__title">施設新築・改修</h3>
            <p class="service__text">曙まちづくりセンター新築工事（2024年竣工）など、地域に根ざした施設の建築・改修を行っています。</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="kenkou">
    <div class="container kenkou__inner">
      <img src={`${base}images/kenkou-keiei.jpg`} alt="健康経営優良法人2026" class="kenkou__badge" width="240" />
      <div class="kenkou__body">
        <h2 class="kenkou__title">健康経営優良法人2026（中小規模法人部門）に認定されました！</h2>
        <p class="kenkou__text">社員の健康管理を経営的な視点で考え、戦略的に実践する企業として、経済産業省より認定を受けました。</p>
      </div>
    </div>
  </section>

  <section class="works-hl">
    <div class="container">
      <div class="section-header">
        <span class="section-header__en">Works</span>
        <h2 class="section-header__ja">施工実績</h2>
      </div>
      <div class="works-hl__item">
        <div class="works-hl__img-wrap">
          <img src={`${base}images/community-center.jpg`} alt="曙まちづくりセンター新築工事" width="800" height="600" />
        </div>
        <div class="works-hl__body">
          <span class="works-hl__tag">公共建築</span>
          <h3 class="works-hl__title">曙まちづくりセンター新築工事</h3>
          <p class="works-hl__meta">2024年10月竣工（JV）</p>
          <p class="works-hl__desc">札幌市都市局から令和5年度優良工事施工業者として表彰を受けた代表的な施工実績です。</p>
        </div>
      </div>
      <div class="works-hl__more">
        <a href={`${base}works/`} class="btn btn--primary">施工実績をもっと見る</a>
      </div>
    </div>
  </section>

  <section class="proof">
    <div class="container">
      <div class="section-header">
        <span class="section-header__en">Trust</span>
        <h2 class="section-header__ja">信頼の証</h2>
      </div>
      <div class="proof__numbers">
        <div class="proof__num-item">
          <span class="proof__num-value">1953</span>
          <span class="proof__num-label">年創業</span>
        </div>
        <div class="proof__num-item">
          <span class="proof__num-value">13</span>
          <span class="proof__num-label">回 札幌市優良工事表彰</span>
        </div>
        <div class="proof__num-item">
          <span class="proof__num-value">122</span>
          <span class="proof__num-label">局 郵便局修繕指定</span>
        </div>
      </div>
      <div class="proof__badges">
        <img src={`${base}images/kenkou-keiei.jpg`} alt="健康経営優良法人2026" width="200" />
        <img src={`${base}images/sapporo-sdgs.jpg`} alt="SAPPORO SDGs" width="150" />
        <img src={`${base}images/sapporo-qms.gif`} alt="サッポロQMS" width="80" />
      </div>
    </div>
  </section>

  <Cta />

</Base>

<style>
  .hero {
    position: relative;
    height: 100svh;
    min-height: 600px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    z-index: 0;
  }
  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--sp-lg);
    width: 100%;
  }
  .hero__heading {
    margin-bottom: var(--sp-md);
  }
  .hero__line {
    display: block;
    font-family: var(--ff-serif);
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 700;
    color: var(--c-accent);
    line-height: 1.2;
  }
  .hero__line--num {
    font-family: var(--ff-condensed);
    font-size: clamp(6rem, 15vw, 12rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--c-accent);
  }
  .hero__line--unit {
    font-family: var(--ff-serif);
    font-size: clamp(3rem, 7vw, 5.5rem);
    letter-spacing: 0;
  }
  .hero__sub {
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    color: var(--c-orange);
    font-weight: 700;
    margin-bottom: var(--sp-lg);
  }
  .hero__kenkou {
    position: absolute;
    right: 5%;
    bottom: 15%;
    display: flex;
    align-items: center;
    gap: var(--sp-sm);
    background: rgba(255,255,255,0.9);
    padding: 12px 20px;
    border-radius: 6px;
    z-index: 2;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  }
  .hero__kenkou img { border-radius: 4px; }
  .hero__kenkou-text {
    font-size: var(--fs-small);
    font-weight: 700;
    color: var(--c-accent);
  }
  @media (max-width: 768px) {
    .hero__kenkou { right: var(--sp-md); bottom: var(--sp-md); }
    .hero__kenkou img { width: 100px; }
  }
  .hero__cta-btn {
    display: inline-block;
    padding: 14px 36px;
    background: var(--c-orange);
    color: var(--c-white);
    font-weight: 700;
    font-size: 1rem;
    border-radius: 4px;
    transition: var(--transition);
  }
  .hero__cta-btn:hover {
    background: var(--c-orange-dark);
  }

  @media (max-width: 768px) {
    .hero { align-items: flex-start; padding-top: var(--sp-xl); }
    .hero__content { padding-top: var(--sp-lg); }
    .hero__bg { object-position: 70% center; }
  }

  .service__lead {
    text-align: center;
    max-width: 700px;
    margin: 0 auto var(--sp-xl);
    color: var(--c-text-light);
    line-height: 1.8;
  }
  .service { padding: var(--sp-4xl) 0; background: var(--c-white); }
  .service__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-lg); }
  .service__item { display: block; overflow: hidden; border-radius: 6px; background: var(--c-warm-gray); transition: var(--transition); }
  .service__item:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
  .service__img-wrap { overflow: hidden; }
  .service__img-wrap img { width: 100%; aspect-ratio: 4/3; object-fit: cover; transition: transform 0.4s ease; }
  .service__item:hover .service__img-wrap img { transform: scale(1.04); }
  .service__body { padding: var(--sp-md); }
  .service__title { font-family: var(--ff-serif); font-size: var(--fs-h3); font-weight: 700; color: var(--c-accent); margin-bottom: var(--sp-xs); }
  .service__text { font-size: var(--fs-small); color: var(--c-text-light); line-height: 1.8; }
  @media (max-width: 768px) { .service__grid { grid-template-columns: 1fr; } }

  .kenkou {
    padding: var(--sp-3xl) 0;
    background: var(--c-orange-light);
  }
  .kenkou__inner {
    display: flex;
    align-items: center;
    gap: var(--sp-xl);
  }
  .kenkou__badge { flex-shrink: 0; }
  .kenkou__title {
    font-family: var(--ff-serif);
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--c-accent);
    margin-bottom: var(--sp-xs);
  }
  .kenkou__text {
    font-size: var(--fs-small);
    color: var(--c-text-light);
    line-height: 1.8;
  }
  @media (max-width: 768px) {
    .kenkou__inner { flex-direction: column; text-align: center; }
    .kenkou__badge { width: 180px; }
  }

  .works-hl { padding: var(--sp-4xl) 0; background: var(--c-warm-gray); }
  .works-hl__item { display: grid; grid-template-columns: 1.2fr 1fr; gap: var(--sp-xl); align-items: center; }
  .works-hl__img-wrap { border-radius: 6px; overflow: hidden; }
  .works-hl__img-wrap img { width: 100%; aspect-ratio: 4/3; object-fit: cover; }
  .works-hl__tag { display: inline-block; font-size: 0.75rem; font-weight: 700; color: var(--c-orange); background: var(--c-orange-light); padding: 4px 12px; border-radius: 3px; margin-bottom: var(--sp-sm); }
  .works-hl__title { font-family: var(--ff-serif); font-size: var(--fs-h3); font-weight: 700; color: var(--c-accent); margin-bottom: var(--sp-xs); }
  .works-hl__meta { font-size: var(--fs-small); color: var(--c-text-light); margin-bottom: var(--sp-sm); }
  .works-hl__desc { font-size: var(--fs-small); color: var(--c-text); line-height: 1.8; }
  .works-hl__more { text-align: center; margin-top: var(--sp-xl); }
  @media (max-width: 768px) { .works-hl__item { grid-template-columns: 1fr; } }

  .proof { padding: var(--sp-4xl) 0; background: var(--c-white); }
  .proof__numbers { display: flex; justify-content: center; gap: var(--sp-2xl); margin-bottom: var(--sp-xl); flex-wrap: wrap; }
  .proof__num-item { text-align: center; }
  .proof__num-value { font-family: var(--ff-condensed); font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 700; color: var(--c-accent); line-height: 1.1; display: block; }
  .proof__num-label { font-size: var(--fs-small); color: var(--c-text-light); display: block; margin-top: 4px; }
  .proof__badges { display: flex; justify-content: center; align-items: center; gap: var(--sp-lg); flex-wrap: wrap; padding: var(--sp-lg); background: var(--c-warm-gray); border-radius: 8px; }
</style>
